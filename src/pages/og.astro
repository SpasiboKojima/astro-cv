---
import { jobs, location, position } from '~/data';
import Layout from '~/layouts/Layout.astro';
import WorkIcon from '~/assets/images/employers/coherent.svg';
import LocationIcon from '~/assets/icons/location.svg';
import Building2Icon from '~/assets/icons/building2.svg';
---

<Layout>
	<div
		style={{
			backgroundImage:
				'radial-gradient(circle at 25px 25px, lightgray 2%, transparent 0%), radial-gradient(circle at 75px 75px, lightgray 2%, transparent 0%)',
			backgroundSize: '100px 100px',
		}}
		class='font-geist f flex h-157.5 w-300 flex-col items-center justify-center bg-gray-50 p-16 text-center text-3xl leading-tight tracking-tighter text-gray-900'
	>
		<WorkIcon width={180} height={180} class='mt-auto' />
		<div class='mt-8 text-5xl'>Andrew Katsewich</div>
		<div class='mt-2 mb-auto text-3xl text-gray-700'>{position}</div>
		<div class='flex w-full items-center justify-between'>
			<div class='flex items-center gap-1'>
				<Building2Icon class='shrink-0' width={32} height={32} />
				{jobs[0].employerName}
			</div>
			<div class='flex items-center gap-1'>
				<LocationIcon class='shrink-0' width={32} height={32} />
				{location}
			</div>
		</div>
	</div>
</Layout>
