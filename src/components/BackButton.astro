---
import ArrowMoveLeftIcon from '~/assets/icons/arrowMoveLeft.svg';
---

<a
	href='/'
	class='group btn btn-circle fixed bottom-8 left-8 z-20 flex size-auto items-center border-none bg-white/75 p-4 backdrop-blur-md lg:hidden dark:bg-zinc-900/75'
	style={{
		boxShadow: '0px -2px 2px rgba(0, 0, 0, 0.05), 0px 2px 4px rgba(0, 0, 0, 0.05), inset 0px 1px 0px 0px rgba(255, 255, 255, 0.15)',
	}}
	aria-label='Back to Home page'
>
	<ArrowMoveLeftIcon class='stroke-base-content size-6 transition-transform group-hover:-translate-x-1' />
</a>
